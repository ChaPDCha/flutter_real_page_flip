default_platform(:android)

platform :android do
  desc "Deploy to Play Store Closed Alpha Testing track"
  lane :deploy do
    # AAB path relative to fastlane/ directory
    aab_path = File.expand_path("../../build/app/outputs/bundle/release/app-release.aab", __dir__)

    # Ensure the AAB exists
    unless File.exist?(aab_path)
      UI.user_error!("AAB not found at #{aab_path}. Run `flutter build appbundle --release` first.")
    end

    upload_to_play_store(
      package_name: 'app.realbook.reader',
      track: 'alpha',
      release_status: 'completed',
      aab: aab_path,
      metadata_path: File.expand_path('metadata/android', __dir__),
      json_key: File.expand_path('play-service-account.json', __dir__),
      skip_upload_apk: true,
      skip_upload_metadata: false,
      skip_upload_changelogs: false,
      skip_upload_images: false,
      skip_upload_screenshots: true,
    )
  end

  desc "Upload Play Store metadata only (screenshots, descriptions, etc.)"
  lane :metadata do |options|
    upload_to_play_store(
      package_name: 'app.realbook.reader',
      track: options[:track] || 'internal',
      version_code: options[:version_code],
      metadata_path: File.expand_path('metadata/android', __dir__),
      json_key: File.expand_path('play-service-account.json', __dir__),
      skip_upload_aab: true,
      skip_upload_apk: true,
      skip_upload_changelogs: false,
      skip_upload_images: false,
      skip_upload_screenshots: true,
    )
  end

  desc "Update changelogs for an existing release"
  lane :changelog do |options|
    track = options[:track] || 'alpha'
    vc = options[:version_code]
    UI.user_error!(":version_code is required") unless vc

    upload_to_play_store(
      package_name: 'app.realbook.reader',
      track: track,
      version_code: vc,
      metadata_path: File.expand_path('metadata/android', __dir__),
      json_key: File.expand_path('play-service-account.json', __dir__),
      skip_upload_aab: true,
      skip_upload_apk: true,
      skip_upload_changelogs: false,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_metadata: true,
    )
  end
end
