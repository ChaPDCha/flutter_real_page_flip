# =============================================================================
# Realbook Reader — 환경 변수 설정 샘플
# =============================================================================
# cp .env.example .env
# flutter run --dart-define-from-file=.env
# flutter build appbundle --dart-define-from-file=.env
# =============================================================================

# ── Supabase ────────────────────────────────────────────────────────────────
# Supabase Dashboard > Settings > API > Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Dashboard > Settings > API > anon public 키
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-payload

# ── AdMob ───────────────────────────────────────────────────────────────────
# AdMob > 앱 > 앱 설정에서 앱 ID 확인
ADMOB_ANDROID_APP_ID=ca-app-pub-XXXXXXXXXXXX~YYYYYYYYYY
ADMOB_IOS_APP_ID=

# ── AdMob — 광고 유닛 ID ──────────────────────────────────────────────────
ADMOB_ANDROID_BANNER_ID=ca-app-pub-XXXXXXXXXXXX/YYYYYYYYYY
ADMOB_IOS_BANNER_ID=

# ── 빌드 모드 ──────────────────────────────────────────────────────────────
# false = 테스트 광고 ID 사용, true = 실제 광고 ID 사용
PRODUCTION=false
