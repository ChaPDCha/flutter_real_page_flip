# Realbook Supabase Cloud Sync Environment Configuration Sample
# Copy this file to '.env' and populate your genuine keys:
# cp .env.example .env
#
# To run or build the application with these environment variables, execute:
# flutter run --dart-define-from-file=.env
# flutter build apk --dart-define-from-file=.env

# 1. Supabase Project REST API Endpoint URL
# You can find this in Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co

# 2. Supabase Anonymous Public API Key (anon public)
# You can find this in Supabase Dashboard -> Project Settings -> API -> Project API keys
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-payload
