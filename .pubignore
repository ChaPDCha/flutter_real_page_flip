# Generated by Flutter/Dart; omit from pub package tarball.
.flutter-plugins-dependencies

# Local build, coverage, and analysis artifacts
build/
coverage/
analyze_output.txt
*.log

# Development configs & hooks
.cursor/
.vscode/
.githooks/
.idea/
Makefile

# Development-only markdown plans & prompt guides
AI_DEBUG_PROMPT.md
PLAN_TEST_COVERAGE.md
community_pitches.md
README_LAYOUT_CONSTRAINTS.md
harness/

# Package size reduction: omit heavy test assets and runner tools
test/failures/
tool/
example/pubspec.lock

# Store metadata and generated desktop/mobile shells are not needed to
# understand or run the package example from pub.dev.
example/android/fastlane/
example/linux/
example/macos/
example/windows/

# Keep the current screenshots referenced by pubspec/README, omit historical
# release captures and source copies already present under lib/.
doc/screenshots/page_flip_demo_v*.webp
doc/screenshots/real_page_flip_demo.mp4
doc/math_verification/sources/
